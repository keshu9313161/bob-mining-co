// ─── Tile Types ───────────────────────────────────────────────────────────────
const T = {
  EMPTY: 0,
  DIRT: 1,
  STONE: 2,
  HARD_ROCK: 3,
  BOB_DUST: 20,
  BOB_FLECK: 21,
  BOB_FRAGMENT: 22,
  BOB_SHARD: 23,
  BOB_CHIP: 24,
  BOB_CRYSTAL: 25,
  BOB_CORE: 26,
  BOB_INGOT: 27,
  BOB_VEIN: 28,
  BOB_SEAM: 29,
  BOB_GENESIS: 99,
  CAVE_IN: 30,
  GAS_POCKET: 31,
  WATER_TILE: 32,
  TREASURE_CHEST: 33,
  LAVA_TILE: 34,
  CRYSTAL_WALL: 35,
} as const;
type TileType = (typeof T)[keyof typeof T];

